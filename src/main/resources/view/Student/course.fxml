<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.*?>

<VBox spacing="15" alignment="CENTER" xmlns:fx="http://javafx.com/fxml">

    <Label text="Course Details" style="-fx-font-size:18px; -fx-font-weight:bold;" />

    <TableView fx:id="courseTable" prefHeight="400" prefWidth="700">

        <columns>
            <TableColumn fx:id="courseIdColumn" text="Course ID" prefWidth="100"/>
            <TableColumn fx:id="courseNameColumn" text="Course Name" prefWidth="250"/>
            <TableColumn fx:id="creditColumn" text="Credits" prefWidth="80"/>
            <TableColumn fx:id="lecturerColumn" text="Lecturer" prefWidth="150"/>
            <TableColumn fx:id="typeColumn" text="Type (Theory/Practical)" prefWidth="150"/>
        </columns>

    </TableView>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Refresh"/>
        <Button text="Back"/>
    </HBox>

</VBox>