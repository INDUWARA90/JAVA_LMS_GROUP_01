<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="720.0" prefWidth="1080.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.java_lms_group_01.Controller.Student.StudentDashboardController">
    <left>
        <VBox prefWidth="250.0" style="-fx-background-color: #1e3a8a;" BorderPane.alignment="CENTER">
            <children>
                <Label text="STUDENT PANEL" textFill="WHITE">
                    <font><Font name="System Bold" size="22.0" /></font>
                    <VBox.margin><Insets left="20.0" top="25.0" /></VBox.margin>
                </Label>
                <Label fx:id="lblRegistrationNo" text="Registration No: -" textFill="#dbeafe">
                    <VBox.margin><Insets left="20.0" top="8.0" bottom="20.0" /></VBox.margin>
                </Label>
                <ImageView fx:id="imgProfile" fitHeight="84.0" fitWidth="84.0" pickOnBounds="true" preserveRatio="true">
                    <VBox.margin><Insets left="20.0" bottom="18.0" /></VBox.margin>
                </ImageView>

                <Button text="  My Profile" onAction="#navProfile" prefHeight="42" prefWidth="250" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;"/>
                <Button text="  Attendance" onAction="#navAttendance" prefHeight="42" prefWidth="250" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;"/>
                <Button text="  Medical" onAction="#navMedical" prefHeight="42" prefWidth="250" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;"/>
                <Button text="  Courses" onAction="#navCourses" prefHeight="42" prefWidth="250" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;"/>
                <Button text="  Course Materials" onAction="#navMaterials" prefHeight="42" prefWidth="250" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;"/>
                <Button text="  Grades and GPA" onAction="#navGrades" prefHeight="42" prefWidth="250" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;"/>
                <Button text="  Timetable" onAction="#navTimetable" prefHeight="42" prefWidth="250" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;"/>
                <Button text="  Notices" onAction="#navNotices" prefHeight="42" prefWidth="250" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;"/>

                <Button text="Logout" onAction="#logout" prefHeight="45" prefWidth="220" style="-fx-background-color: #dc2626; -fx-text-fill: white; -fx-font-weight: bold;">
                    <VBox.margin><Insets left="15.0" right="15.0" top="25.0" /></VBox.margin>
                </Button>
            </children>
        </VBox>
    </left>
    <center>
        <AnchorPane fx:id="contentArea" style="-fx-background-color: #f3f4f6;" BorderPane.alignment="CENTER" />
    </center>
</BorderPane>
