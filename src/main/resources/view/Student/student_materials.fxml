<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12.0" style="-fx-padding: 18; -fx-background-color: white;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.java_lms_group_01.Controller.Student.StudentMaterialsPageController">
    <Label text="Course Materials" style="-fx-font-size: 20px; -fx-font-weight: bold;" />

    <HBox spacing="10.0">
        <children>
            <Button text="Download" onAction="#downloadSelectedMaterial" />
        </children>
    </HBox>

    <TableView fx:id="tblMaterials" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colCourseCode" text="Course" prefWidth="130.0" />
            <TableColumn fx:id="colMaterialName" text="Material Name" prefWidth="220.0" />
            <TableColumn fx:id="colType" text="Type" prefWidth="120.0" />
        </columns>
    </TableView>
</VBox>
