<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.java_lms_group_01.Controller.Student.StudentMedicalPageController"
      style="-fx-padding: 18; -fx-background-color: white;">
    <Label text="Medical Details" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
    <TableView fx:id="tblMedical" prefHeight="450">
        <columns>
            <TableColumn fx:id="colCourseCode" text="courseCode" prefWidth="120"/>
            <TableColumn fx:id="colSubmissionDate" text="SubmissionDate" prefWidth="120"/>
            <TableColumn fx:id="colDescription" text="Description" prefWidth="260"/>
            <TableColumn fx:id="colSessionType" text="session_type" prefWidth="110"/>
            <TableColumn fx:id="colApprovalStatus" text="approval_status" prefWidth="120"/>
        </columns>
    </TableView>
</VBox>
