<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.java_lms_group_01.Controller.Student.StudentGradePageController"
      style="-fx-padding: 18; -fx-background-color: white;">
    <Label text="Grades and GPA" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
    <TableView fx:id="tblGrades" prefHeight="420">
        <columns>
            <TableColumn fx:id="colCourseCode" text="courseCode" prefWidth="120"/>
            <TableColumn fx:id="colQuiz1" text="quiz_1" prefWidth="85"/>
            <TableColumn fx:id="colQuiz2" text="quiz_2" prefWidth="85"/>
            <TableColumn fx:id="colQuiz3" text="quiz_3" prefWidth="85"/>
            <TableColumn fx:id="colAssessment1" text="assessment_1" prefWidth="100"/>
            <TableColumn fx:id="colAssessment2" text="assessment_2" prefWidth="100"/>
            <TableColumn fx:id="colMidTerm" text="mid_term" prefWidth="90"/>
            <TableColumn fx:id="colFinalTheory" text="final_theory" prefWidth="100"/>
            <TableColumn fx:id="colFinalPractical" text="final_practical" prefWidth="110"/>
            <TableColumn fx:id="colTotal" text="Total" prefWidth="85"/>
            <TableColumn fx:id="colGrade" text="Grade" prefWidth="80"/>
        </columns>
    </TableView>
    <Label fx:id="lblGpa" text="GPA : 0.00" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
</VBox>
