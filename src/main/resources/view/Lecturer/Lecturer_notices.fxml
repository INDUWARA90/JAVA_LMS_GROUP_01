<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="12.0" style="-fx-padding: 18; -fx-background-color: white;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.java_lms_group_01.Controller.Lecturer.LecturerNoticesController">
    <Label text="University Notices">
        <font>
            <Font name="System Bold" size="22.0" />
        </font>
    </Label>

    <HBox spacing="10.0">
        <children>
            <TextField fx:id="txtSearch" promptText="Search notices" />
            <Button text="Search" onAction="#searchNotices" />
            <Button text="Refresh" onAction="#refreshNotices" />
        </children>
    </HBox>

    <TableView fx:id="tblNotices" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colNoticeId" text="ID" prefWidth="80.0" />
            <TableColumn fx:id="colTitle" text="Title" prefWidth="190.0" />
            <TableColumn fx:id="colContent" text="Content" prefWidth="410.0" />
            <TableColumn fx:id="colDate" text="Date" prefWidth="110.0" />
            <TableColumn fx:id="colCreatedBy" text="Created By" prefWidth="120.0" />
        </columns>
    </TableView>
</VBox>
