<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="12.0" style="-fx-padding: 18; -fx-background-color: white;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.java_lms_group_01.Controller.Lecturer.LecturerMaterialsController">
    <Label text="Manage Course Materials">
        <font>
            <Font name="System Bold" size="22.0" />
        </font>
    </Label>

    <HBox spacing="10.0">
        <children>
            <TextField fx:id="txtCourseCode" promptText="Course Code" />
            <TextField fx:id="txtMaterialName" promptText="Material Name" />
            <TextField fx:id="txtPath" promptText="File Path / URL" />
            <ComboBox fx:id="cmbMaterialType" promptText="Material Type" prefWidth="130.0" />
        </children>
    </HBox>

    <HBox spacing="10.0">
        <children>
            <Button text="Add" onAction="#addMaterial" />
            <Button text="Update" onAction="#updateMaterial" />
            <Button text="Delete" onAction="#deleteMaterial" />
            <Button text="Clear" onAction="#clearForm" />
            <TextField fx:id="txtSearch" promptText="Search by course/material" />
            <Button text="Search" onAction="#searchMaterials" />
            <Button text="Refresh" onAction="#refreshMaterials" />
        </children>
    </HBox>

    <TableView fx:id="tblMaterials" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colMaterialId" text="ID" prefWidth="70.0" />
            <TableColumn fx:id="colCourseCode" text="Course" prefWidth="130.0" />
            <TableColumn fx:id="colMaterialName" text="Material Name" prefWidth="190.0" />
            <TableColumn fx:id="colPath" text="Path" prefWidth="260.0" />
            <TableColumn fx:id="colType" text="Type" prefWidth="110.0" />
            <TableColumn fx:id="colLecturerReg" text="Lecturer" prefWidth="120.0" />
        </columns>
    </TableView>
</VBox>
