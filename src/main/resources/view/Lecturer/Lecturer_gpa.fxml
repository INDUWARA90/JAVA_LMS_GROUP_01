<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="12.0" style="-fx-padding: 18; -fx-background-color: white;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.java_lms_group_01.Controller.Lecturer.LecturerGpaController">
    <Label text="Academic Results, Final Marks and GPA">
        <font>
            <Font name="System Bold" size="22.0" />
        </font>
    </Label>
    <HBox spacing="10.0">
        <children>
            <ComboBox fx:id="cmbBatch" prefWidth="150.0" promptText="Batch" />
            <TextField fx:id="txtStudentSearch" prefWidth="220.0" promptText="Search one student by reg or name" />
            <Button text="Submit" onAction="#submitFilters" />
        </children>
    </HBox>

    <TabPane VBox.vgrow="ALWAYS">
        <tabs>
            <Tab closable="false" text="Subject Results">
                <TableView fx:id="tblPerformance">
                    <columns>
                        <TableColumn fx:id="colStudentReg" text="Student Reg" prefWidth="120.0" />
                        <TableColumn fx:id="colStudentName" text="Student Name" prefWidth="180.0" />
                        <TableColumn fx:id="colCourseCode" text="Course Code" prefWidth="110.0" />
                        <TableColumn fx:id="colCourseName" text="Course Name" prefWidth="180.0" />
                        <TableColumn fx:id="colCaMarks" text="CA Marks" prefWidth="95.0" />
                        <TableColumn fx:id="colResultFinalMarks" text="Final Marks" prefWidth="95.0" />
                        <TableColumn fx:id="colTotalMarks" text="Total Marks" prefWidth="100.0" />
                        <TableColumn fx:id="colGrade" text="Grade" prefWidth="80.0" />
                        <TableColumn fx:id="colSgpa" text="SGPA" prefWidth="80.0" />
                        <TableColumn fx:id="colCgpa" text="CGPA" prefWidth="80.0" />
                    </columns>
                </TableView>
            </Tab>
            <Tab closable="false" text="SGPA / CGPA">
                <TableView fx:id="tblUndergraduateSummary">
                    <columns>
                        <TableColumn fx:id="colSummaryStudentReg" text="Student Reg" prefWidth="140.0" />
                        <TableColumn fx:id="colSummaryStudentName" text="Student Name" prefWidth="260.0" />
                        <TableColumn fx:id="colSummarySgpa" text="SGPA" prefWidth="120.0" />
                        <TableColumn fx:id="colSummaryCgpa" text="CGPA" prefWidth="120.0" />
                    </columns>
                </TableView>
            </Tab>
        </tabs>
    </TabPane>
</VBox>
