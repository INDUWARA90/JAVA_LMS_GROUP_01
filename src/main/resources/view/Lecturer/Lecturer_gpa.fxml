<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="12.0" style="-fx-padding: 18; -fx-background-color: white;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.java_lms_group_01.Controller.Lecturer.LecturerGpaController">
    <Label text="Undergraduate Marks, Grades and GPA">
        <font>
            <Font name="System Bold" size="22.0" />
        </font>
    </Label>

    <HBox spacing="10.0">
        <children>
            <TextField fx:id="txtSearch" promptText="Search by student/course" />
            <Button text="Search" onAction="#searchPerformance" />
            <Button text="Refresh" onAction="#refreshPerformance" />
        </children>
    </HBox>

    <TableView fx:id="tblPerformance" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colStudentReg" text="Student Reg" prefWidth="120.0" />
            <TableColumn fx:id="colStudentName" text="Student Name" prefWidth="220.0" />
            <TableColumn fx:id="colCourseCode" text="Course" prefWidth="120.0" />
            <TableColumn fx:id="colTotalMarks" text="Total Marks" prefWidth="120.0" />
            <TableColumn fx:id="colGrade" text="Grade" prefWidth="90.0" />
            <TableColumn fx:id="colGpa" text="GPA" prefWidth="90.0" />
        </columns>
    </TableView>
</VBox>
