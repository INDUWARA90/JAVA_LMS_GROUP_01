<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="620.0" prefWidth="800.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.java_lms_group_01.Controller.Admin.ManageNoticesController">
    <children>
        <VBox layoutX="20.0" layoutY="20.0" spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <Label text="Notice Board Management" textFill="#2c3e50">
                    <font><Font name="System Bold" size="22.0" /></font>
                </Label>

                <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #f1f2f6; -fx-padding: 10; -fx-background-radius: 10;">
                    <children>
                        <TextField fx:id="txtSearchNotice" prefHeight="35.0" prefWidth="400.0" promptText="Search notices by title or content..." style="-fx-background-radius: 5;" />
                        <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                            <children>
                                <Button onAction="#btnOnActionAddNewNotice" prefHeight="35.0" style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-weight: bold;" text="+ CREATE NOTICE" />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <TableView fx:id="tblNotices" prefHeight="400.0" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNoticeId" prefWidth="70.0" text="ID" />
                        <TableColumn fx:id="colTitle" prefWidth="250.0" text="Title" />
                        <TableColumn fx:id="colDate" prefWidth="120.0" text="Posted Date" />
                        <TableColumn fx:id="colAuthor" prefWidth="150.0" text="Created By" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="15.0">
                    <children>
                        <Button onAction="#btnOnActionViewNotice" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #34495e; -fx-text-fill: white;" text="View/Edit" />
                        <Button onAction="#btnOnActionDeleteNotice" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Delete" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
