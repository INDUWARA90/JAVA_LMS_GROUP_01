<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="620.0" prefWidth="800.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.java_lms_group_01.Controller.Admin.ManageCoursesController">
    <children>
        <VBox layoutX="20.0" layoutY="20.0" spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <Label text="Course Management" textFill="#2c3e50">
                    <font><Font name="System Bold" size="22.0" /></font>
                </Label>

                <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #f1f2f6; -fx-padding: 10; -fx-background-radius: 10;">
                    <children>
                        <TextField fx:id="txtSearchCourse" prefHeight="35.0" prefWidth="350.0" promptText="Search by Course Name or Code..." style="-fx-background-radius: 5;" />
                        <ComboBox fx:id="cmbDeptFilter" prefHeight="35.0" prefWidth="180.0" promptText="Department" />
                        <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                            <children>
                                <Button onAction="#btnOnActionAddNewCourse" prefHeight="35.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;" text="+ NEW COURSE" />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <TableView fx:id="tblCourses" prefHeight="400.0" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colCourseCode" prefWidth="86.0" text="courseCode" />
                        <TableColumn fx:id="colName" prefWidth="49.0" text="name" />
                        <TableColumn fx:id="colCredits" prefWidth="61.0" text="credit" />
                        <TableColumn fx:id="colHasTheory" prefWidth="85.0" text="course_type" />
                  <TableColumn fx:id="colHasPractical" prefWidth="115.0" text="-" />
                  <TableColumn fx:id="colLecturerId" prefWidth="103.0" text="lecturerRegistrationNo" />
                  <TableColumn fx:id="colDeptId" prefWidth="116.0" text="department" />
                  <TableColumn fx:id="colSemester" prefWidth="173.0" text="semester" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="15.0">
                    <children>
                        <Button onAction="#btnOnActionUpdateCourse" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #f39c12; -fx-text-fill: white;" text="Edit" />
                        <Button onAction="#btnOnActionDeleteCourse" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Delete" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
