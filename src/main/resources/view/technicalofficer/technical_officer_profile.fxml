<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="12.0" style="-fx-padding: 18; -fx-background-color: white;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.java_lms_group_01.Controller.TechnicalOfficer.TechnicalOfficerProfileController">
    <Label text="My Profile">
        <font>
            <Font name="System Bold" size="22.0" />
        </font>
    </Label>

    <Label text="Username and password are managed by admin and cannot be changed here." style="-fx-text-fill: #475569;" />

    <GridPane hgap="10.0" vgap="10.0">
        <children>
            <Label text="Registration No" GridPane.rowIndex="0" GridPane.columnIndex="0" />
            <TextField fx:id="txtRegistrationNo" GridPane.rowIndex="0" GridPane.columnIndex="1" />

            <Label text="First Name" GridPane.rowIndex="1" GridPane.columnIndex="0" />
            <TextField fx:id="txtFirstName" GridPane.rowIndex="1" GridPane.columnIndex="1" />

            <Label text="Last Name" GridPane.rowIndex="2" GridPane.columnIndex="0" />
            <TextField fx:id="txtLastName" GridPane.rowIndex="2" GridPane.columnIndex="1" />

            <Label text="Email" GridPane.rowIndex="3" GridPane.columnIndex="0" />
            <TextField fx:id="txtEmail" GridPane.rowIndex="3" GridPane.columnIndex="1" />

            <Label text="Phone" GridPane.rowIndex="4" GridPane.columnIndex="0" />
            <TextField fx:id="txtPhone" GridPane.rowIndex="4" GridPane.columnIndex="1" />

            <Label text="Address" GridPane.rowIndex="5" GridPane.columnIndex="0" />
            <TextField fx:id="txtAddress" GridPane.rowIndex="5" GridPane.columnIndex="1" />
        </children>
    </GridPane>

    <Button text="Save Profile" onAction="#saveProfile" prefWidth="150.0" />
</VBox>
