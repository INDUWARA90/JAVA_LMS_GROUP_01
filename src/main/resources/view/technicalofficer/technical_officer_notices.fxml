<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="12.0" style="-fx-padding: 18; -fx-background-color: white;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.java_lms_group_01.Controller.TechnicalOfficer.TechnicalOfficerNoticesController">
    <Label text="Notices">
        <font>
            <Font name="System Bold" size="22.0" />
        </font>
    </Label>

    <HBox spacing="10.0">
        <children>
            <TextField fx:id="txtSearch" promptText="Search notices by title/content" />
            <DatePicker fx:id="dpPublishedDate" promptText="Published Date" />
            <Button mnemonicParsing="false" onAction="#searchNotices" text="Search" />
            <Button mnemonicParsing="false" onAction="#refreshNotices" text="Refresh" />
        </children>
    </HBox>

    <TableView fx:id="tblNotices" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colNoticeId" prefWidth="100.0" text="Notice ID" />
            <TableColumn fx:id="colTitle" prefWidth="240.0" text="Title" />
            <TableColumn fx:id="colContent" prefWidth="420.0" text="Content" />
            <TableColumn fx:id="colPublishDate" prefWidth="140.0" text="Publish Date" />
            <TableColumn fx:id="colCreatedBy" prefWidth="140.0" text="Created By" />
        </columns>
    </TableView>
</VBox>
